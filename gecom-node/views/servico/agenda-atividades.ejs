<% contentFor('headerLink') %>
  <link href="/Assets/inspinia/css/plugins/fullcalendar/fullcalendar.css" rel="stylesheet">
  <link href="/Assets/inspinia/css/plugins/fullcalendar/fullcalendar.print.css" rel="stylesheet" media="print">
<% %>

<style>
  .cal-activities-layout .ibox-title {
    padding: 14px 15px;
  }

  .cal-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    flex-wrap: wrap;
  }

  .cal-toolbar .btn-group .dropdown-menu {
    max-height: 280px;
    overflow-y: auto;
  }

  .cal-toolbar-actions {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  #calendarActivities {
    min-height: 680px;
  }

  .activity-filters {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .activity-filter-item {
    display: flex;
    align-items: center;
    gap: 10px;
    border: 1px solid #e7eaec;
    border-radius: 4px;
    padding: 8px 10px;
    background: #fff;
  }

  .activity-filter-color {
    width: 12px;
    height: 12px;
    border-radius: 3px;
    display: inline-block;
  }

  .activity-filter-label {
    flex: 1;
    font-size: 13px;
    color: #3a3a3a;
  }

  .activity-filter-actions {
    margin-top: 12px;
    display: flex;
    gap: 8px;
  }

  .activity-side-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, .28);
    z-index: 1000008;
    display: none;
  }

  .activity-side-overlay.is-open {
    display: block;
  }

  .activity-side {
    position: fixed;
    top: 0;
    right: -560px;
    width: 540px;
    max-width: calc(100vw - 20px);
    height: 100vh;
    background: #fff;
    box-shadow: -4px 0 22px rgba(0, 0, 0, .18);
    z-index: 1000009;
    transition: right .2s ease;
    display: flex;
    flex-direction: column;
  }

  .activity-side.is-open {
    right: 0;
  }

  .activity-side-head {
    border-bottom: 1px solid #e7eaec;
    padding: 14px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .activity-side-body {
    padding: 14px 16px;
    overflow-y: auto;
    flex: 1;
  }

  .activity-side-footer {
    border-top: 1px solid #e7eaec;
    padding: 12px 16px;
    display: flex;
    justify-content: flex-end;
    gap: 8px;
  }

  .activity-form-error {
    display: none;
    margin-bottom: 10px;
  }

  .activity-form-error.is-open {
    display: block;
  }

  .activity-lookup-wrap {
    position: relative;
  }

  .activity-lookup-wrap .dropdown-menu {
    width: 100%;
    max-height: 260px;
    overflow-y: auto;
  }

  .activity-lookup-subtitle {
    font-size: 11px;
    color: #888;
  }

  @media (max-width: 991px) {
    .cal-activities-layout .col-lg-3 {
      margin-top: 16px;
    }

    #calendarActivities {
      min-height: 560px;
    }
  }
</style>

<div class="wrapper wrapper-content cal-activities-layout">
  <div class="row animated fadeInDown">
    <div class="col-lg-9">
      <div class="ibox">
        <div class="ibox-title">
          <div class="cal-toolbar">
            <h5 style="margin:0;">Calendário de Atividades</h5>
            <div class="cal-toolbar-actions">
              <div class="btn-group">
                <button id="calendarAddBtn" data-toggle="dropdown" class="btn btn-primary dropdown-toggle" type="button">
                  <i class="fa fa-plus"></i> Adicionar <span class="caret"></span>
                </button>
                <ul id="calendarAddMenu" class="dropdown-menu"></ul>
              </div>
              <button id="calendarRefreshBtn" type="button" class="btn btn-white">
                <i class="fa fa-refresh"></i> Atualizar
              </button>
            </div>
          </div>
        </div>
        <div class="ibox-content">
          <div id="calendarActivities"></div>
        </div>
      </div>
    </div>

    <div class="col-lg-3">
      <div class="ibox">
        <div class="ibox-title">
          <h5 style="margin:0;">Tipos de Atividades</h5>
        </div>
        <div class="ibox-content">
          <div id="activityFilters" class="activity-filters"></div>
          <div class="activity-filter-actions">
            <button id="activitySelectAll" type="button" class="btn btn-xs btn-primary">Selecionar todos</button>
            <button id="activityClearAll" type="button" class="btn btn-xs btn-white">Limpar</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div id="activitySideOverlay" class="activity-side-overlay"></div>
<aside id="activitySidePanel" class="activity-side" aria-hidden="true">
  <div class="activity-side-head">
    <h4 id="activitySideTitle" style="margin:0;">Nova atividade</h4>
    <button id="activitySideClose" type="button" class="btn btn-xs btn-default"><i class="fa fa-times"></i></button>
  </div>
  <form id="activityForm" class="activity-side-body">
    <div id="activityFormError" class="alert alert-danger activity-form-error"></div>
    <input id="activityTypeInput" type="hidden" />
    <div id="activityFormFields" class="row"></div>
  </form>
  <div class="activity-side-footer">
    <button id="activityCancelBtn" type="button" class="btn btn-white">Cancelar</button>
    <button id="activitySaveBtn" type="submit" form="activityForm" class="btn btn-primary"><i class="fa fa-save"></i> Salvar</button>
  </div>
</aside>

<div id="activityEventDetailModal" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal" aria-label="Fechar"><span aria-hidden="true">&times;</span></button>
        <h4 id="activityEventDetailTitle" class="modal-title">Detalhes do evento</h4>
      </div>
      <div class="modal-body">
        <div class="table-responsive">
          <table class="table table-striped table-bordered" style="margin-bottom:0;">
            <tbody id="activityEventDetailRows"></tbody>
          </table>
        </div>
        <div id="activityEventRawBox" style="display:none; margin-top:12px;">
          <label style="margin-bottom:6px;">Dados técnicos</label>
          <pre id="activityEventRaw" style="max-height:220px; overflow:auto;"></pre>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-white" data-dismiss="modal">Fechar</button>
      </div>
    </div>
  </div>
</div>

<% contentFor('scripts') %>
  <script src="/Assets/inspinia/js/plugins/fullcalendar/moment.min.js"></script>
  <script src="/Assets/inspinia/js/plugins/fullcalendar/fullcalendar.min.js"></script>
  <script src="/Assets/inspinia/js/plugins/typehead/bootstrap3-typeahead.min.js"></script>
  <script src="/js/servico/serviceApi.js"></script>
  <script src="/js/servico/calendar-activities.page.js"></script>
<% %>
