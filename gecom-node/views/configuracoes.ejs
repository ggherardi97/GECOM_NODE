<style>
  .cfg-toolbar { display:flex; gap:8px; align-items:center; justify-content:space-between; margin-bottom:12px; flex-wrap: wrap; }
  .cfg-layout { display:grid; grid-template-columns: 300px 1fr; gap:14px; }
  .cfg-card { border:1px solid #e7eaec; border-radius:4px; background:#fff; }
  .cfg-card .cfg-card-head { padding:10px 12px; border-bottom:1px solid #e7eaec; font-weight:600; }
  .cfg-card .cfg-card-body { padding:12px; }
  .cfg-area-list { list-style:none; margin:0; padding:0; min-height: 80px; }
  .cfg-area-list li { border:1px solid #e7eaec; border-radius:4px; padding:8px 10px; margin-bottom:8px; cursor:pointer; background:#fff; }
  .cfg-area-list li.active { border-color:#1ab394; background:#f3fbfa; }
  .cfg-item-list { list-style:none; margin:0; padding:0; min-height: 80px; }
  .cfg-item-list li { border:1px solid #e7eaec; border-radius:4px; padding:8px 10px; margin-bottom:8px; cursor:move; background:#fff; display:flex; justify-content:space-between; gap:8px; }
  .cfg-preview-box { border:1px dashed #ced4da; border-radius:6px; overflow:hidden; }
  .cfg-preview-topbar { padding:8px 10px; background: var(--cfg-topbar, #fff); }
  .cfg-preview-body { display:flex; min-height:140px; }
  .cfg-preview-nav { width:180px; padding:10px; color: var(--cfg-nav-text, #a7b1c2); background: var(--cfg-nav-bg, #2f4050); }
  .cfg-preview-content { flex:1; padding:12px; background:#f8f8f8; }
  .cfg-preview-button { display:inline-block; padding:6px 10px; border-radius:4px; color:#fff; background: var(--cfg-primary, #1ab394); }
  .cfg-badge { display:inline-block; font-size:11px; padding:2px 6px; border-radius:10px; background:#f3f3f4; }
  .cfg-toast { display:none; margin-bottom:10px; }
  .cfg-hidden { display:none !important; }
  .cfg-muted { color:#7d7d7d; }
  .cfg-table-pointer tbody tr { cursor: pointer; }
  .cfg-access-layout { display:grid; grid-template-columns: 320px 1fr; gap:14px; }
  .cfg-access-roles { max-height: 520px; overflow:auto; }
  .cfg-access-users { max-height: 520px; overflow:auto; }
  .cfg-access-perm-table thead th { white-space: nowrap; }
  .cfg-access-perm-table tbody td { vertical-align: middle; }
  .cfg-access-role-item.active { border-color:#1ab394; background:#f3fbfa; }
  .cfg-area-list li.cfg-area-core { background:#38414a; border-color:#2e353c; color:#f2f4f7; }
  .cfg-area-list li.cfg-area-core .cfg-muted { color:#d3d8de; }
  .cfg-area-list li.cfg-area-core.active { border-color:#1ab394; box-shadow: inset 0 0 0 1px rgba(26,179,148,0.4); }
  #cfgTabs > li > a.cfg-main-tab-link.active { color:#1ab394; font-weight:600; }
  .cfg-landing-meta { display:flex; gap:14px; flex-wrap:wrap; margin-top:10px; }
  .cfg-landing-meta .cfg-badge { font-size:12px; }
  #cfgLandingEditorModal .modal-dialog { width:96vw; max-width:96vw; margin:12px auto; }
  #cfgLandingEditorModal .modal-content { height:94vh; }
  #cfgLandingEditorModal .modal-body { height: calc(94vh - 130px); overflow:hidden; padding:0; }
  #cfgLandingEditorRoot { height:100%; }
  .cfg-landing-editor-toolbar { display:flex; gap:8px; align-items:center; flex-wrap:wrap; }
  .cfg-landing-ai-versions { margin-top:10px; display:flex; gap:8px; flex-wrap:wrap; }
  .cfg-landing-ai-versions .btn.active { box-shadow: inset 0 0 0 2px rgba(26,179,148,0.55); }
</style>

<link rel="stylesheet" href="/Assets/inspinia/css/plugins/select2/select2.min.css" />

<div class="row animated fadeInRight" style="margin-top:25px;">
  <div class="col-lg-12">
    <div class="ibox">
      <div class="ibox-title">
        <h5 data-i18n="page.settings.title"><%= t('page.settings.title', { defaultValue: 'Configuracoes' }) %></h5>
      </div>
      <div class="ibox-content">
        <div id="cfgToast" class="alert cfg-toast"></div>

        <ul class="nav nav-tabs" id="cfgTabs">
          <li class="active"><a href="#cfg-tab-menu" class="cfg-main-tab-link active" data-toggle="tab" data-i18n="page.settings.tabs.menu"><%= t('page.settings.tabs.menu', { defaultValue: 'Menu Lateral' }) %></a></li>
          <li><a href="#cfg-tab-theme" class="cfg-main-tab-link" data-toggle="tab" data-i18n="page.settings.tabs.theme"><%= t('page.settings.tabs.theme', { defaultValue: 'Aparencia' }) %></a></li>
          <li><a href="#cfg-tab-status" class="cfg-main-tab-link" data-toggle="tab" data-i18n="page.settings.tabs.status"><%= t('page.settings.tabs.status', { defaultValue: 'Status de Entidades' }) %></a></li>
          <li><a href="#cfg-tab-options" class="cfg-main-tab-link" data-toggle="tab" data-i18n="page.settings.tabs.options"><%= t('page.settings.tabs.options', { defaultValue: 'Option Sets' }) %></a></li>
          <li><a href="#cfg-tab-email" class="cfg-main-tab-link" data-toggle="tab" data-i18n="page.settings.tabs.email"><%= t('page.settings.tabs.email', { defaultValue: 'Integracoes de E-mail' }) %></a></li>
          <li><a href="#cfg-tab-landing" class="cfg-main-tab-link" data-toggle="tab"><%= t('page.settings.tabs.landingPage', { defaultValue: 'Landing Page' }) %></a></li>
          <li><a href="#cfg-tab-access" class="cfg-main-tab-link" data-toggle="tab"><%= t('page.settings.tabs.access', { defaultValue: 'Acessos' }) %></a></li>
        </ul>

        <div class="tab-content" id="cfgMainTabContent" style="margin-top:15px;">
          <div class="tab-pane active" id="cfg-tab-menu">
            <div class="cfg-toolbar">
              <div>
                <button type="button" class="btn btn-primary btn-sm" id="btnCfgSaveMenu"><i class="fa fa-save"></i> <%= t('page.settings.common.save', { defaultValue: 'Salvar' }) %></button>
                <button type="button" class="btn btn-white btn-sm" id="btnCfgReloadMenu"><i class="fa fa-refresh"></i> <%= t('page.settings.common.reload', { defaultValue: 'Recarregar' }) %></button>
                <button type="button" class="btn btn-success btn-sm" id="btnCfgNewArea"><i class="fa fa-plus"></i> <%= t('page.settings.menu.newArea', { defaultValue: 'Nova area' }) %></button>
              </div>
              <div style="display:flex; gap:8px; align-items:center;">
                <label for="cfgDefaultAreaSelect" style="margin:0;"><%= t('page.settings.menu.defaultArea', { defaultValue: 'Área padrão' }) %></label>
                <select id="cfgDefaultAreaSelect" class="form-control input-sm" style="min-width:180px;"></select>
              </div>
            </div>

            <div class="cfg-layout">
              <div class="cfg-card">
                <div class="cfg-card-head"><%= t('page.settings.menu.areas', { defaultValue: 'Areas' }) %></div>
                <div class="cfg-card-body">
                  <ul id="cfgAreaList" class="cfg-area-list"></ul>
                </div>
              </div>

              <div class="cfg-card">
                <div class="cfg-card-head"><%= t('page.settings.menu.areaEditor', { defaultValue: 'Editor da Area' }) %></div>
                <div class="cfg-card-body" id="cfgAreaEditor">
                  <p class="cfg-muted"><%= t('page.settings.menu.selectAreaHelp', { defaultValue: 'Selecione uma area para editar.' }) %></p>
                </div>
              </div>
            </div>
          </div>

          <div class="tab-pane" id="cfg-tab-theme">
            <div class="row">
              <div class="col-md-6">
                <div class="form-group">
                  <label><%= t('page.settings.theme.primaryColor', { defaultValue: 'Cor primaria' }) %></label>
                  <input type="color" class="form-control" id="cfgThemePrimaryColor" />
                </div>
                <div class="form-group">
                  <label><%= t('page.settings.theme.navBgColor', { defaultValue: 'Cor de fundo do menu' }) %></label>
                  <input type="color" class="form-control" id="cfgThemeNavBgColor" />
                </div>
                <div class="form-group">
                  <label><%= t('page.settings.theme.navTextColor', { defaultValue: 'Cor de texto do menu' }) %></label>
                  <input type="color" class="form-control" id="cfgThemeNavTextColor" />
                </div>
                <div class="form-group">
                  <label><%= t('page.settings.theme.topbarBgColor', { defaultValue: 'Cor da topbar' }) %></label>
                  <input type="color" class="form-control" id="cfgThemeTopbarBgColor" />
                </div>
                <div class="form-group">
                  <label><%= t('page.settings.theme.layoutMode', { defaultValue: 'Modo de layout' }) %></label>
                  <select class="form-control" id="cfgThemeLayoutMode">
                    <option value="LIGHT">LIGHT</option>
                    <option value="DARK">DARK</option>
                  </select>
                </div>
                <div class="form-group">
                  <label><%= t('page.settings.theme.logoUrl', { defaultValue: 'Logo URL' }) %></label>
                  <input type="text" class="form-control" id="cfgThemeLogoUrl" placeholder="https://..." />
                </div>
                <div class="form-group">
                  <label><%= t('page.settings.theme.faviconUrl', { defaultValue: 'Favicon URL' }) %></label>
                  <input type="text" class="form-control" id="cfgThemeFaviconUrl" placeholder="https://..." />
                </div>
                <button type="button" class="btn btn-primary btn-sm" id="btnCfgSaveTheme"><i class="fa fa-save"></i> <%= t('page.settings.common.save', { defaultValue: 'Salvar' }) %></button>
              </div>
              <div class="col-md-6">
                <div class="cfg-preview-box" id="cfgThemePreview">
                  <div class="cfg-preview-topbar"><strong><%= t('page.settings.theme.preview.topbar', { defaultValue: 'Topbar' }) %></strong></div>
                  <div class="cfg-preview-body">
                    <div class="cfg-preview-nav">
                      <div style="margin-bottom:8px;"><strong><%= t('page.settings.theme.preview.menu', { defaultValue: 'Menu' }) %></strong></div>
                      <div><%= t('page.layout.menu.dashboard', { defaultValue: 'Dashboard' }) %></div>
                      <div><%= t('page.layout.menu.processes', { defaultValue: 'Processos' }) %></div>
                      <div><%= t('page.layout.menu.finance', { defaultValue: 'Financeiro' }) %></div>
                    </div>
                    <div class="cfg-preview-content">
                      <div class="cfg-preview-button"><%= t('page.settings.theme.preview.primaryButton', { defaultValue: 'Botao primario' }) %></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="tab-pane" id="cfg-tab-status">
            <%- include('StatusConfigs') %>
          </div>

          <div class="tab-pane" id="cfg-tab-options">
            <div class="cfg-toolbar">
              <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
                <select class="form-control" id="cfgOptionEntity" style="min-width:240px;"></select>
                <select class="form-control" id="cfgOptionField" style="min-width:240px;"></select>
                <button type="button" class="btn btn-primary btn-sm" id="btnCfgLoadOptionSets"><i class="fa fa-search"></i> <%= t('page.settings.options.load', { defaultValue: 'Carregar' }) %></button>
                <button type="button" class="btn btn-success btn-sm" id="btnCfgCreateOptionSet"><i class="fa fa-plus"></i> <%= t('page.settings.options.newSet', { defaultValue: 'Novo option set' }) %></button>
              </div>
            </div>

            <div class="row">
              <div class="col-md-5">
                <div class="cfg-card">
                  <div class="cfg-card-head"><%= t('page.settings.options.sets', { defaultValue: 'Option Sets' }) %></div>
                  <div class="cfg-card-body">
                    <table class="table table-striped table-bordered cfg-table-pointer" id="cfgOptionSetTable">
                      <thead>
                        <tr>
                          <th><%= t('page.settings.options.entity', { defaultValue: 'Entidade' }) %></th>
                          <th><%= t('page.settings.options.field', { defaultValue: 'Campo' }) %></th>
                        </tr>
                      </thead>
                      <tbody></tbody>
                    </table>
                  </div>
                </div>
              </div>
              <div class="col-md-7">
                <div class="cfg-card">
                  <div class="cfg-card-head"><%= t('page.settings.options.options', { defaultValue: 'Opcoes' }) %></div>
                  <div class="cfg-card-body">
                    <div style="display:flex; gap:8px; margin-bottom:10px; align-items:end; flex-wrap:wrap;">
                      <div>
                        <label><%= t('page.settings.options.value', { defaultValue: 'Value' }) %></label>
                        <input type="text" class="form-control" id="cfgOptionValue" placeholder="NOVO_STATUS" />
                      </div>
                      <div>
                        <label><%= t('page.settings.options.label', { defaultValue: 'Label' }) %></label>
                        <input type="text" class="form-control" id="cfgOptionLabel" placeholder="Novo status" />
                      </div>
                      <div>
                        <label><%= t('page.settings.options.color', { defaultValue: 'Cor' }) %></label>
                        <input type="color" class="form-control" id="cfgOptionColor" value="#64748B" />
                      </div>
                      <div>
                        <label><%= t('page.settings.options.sortOrder', { defaultValue: 'Ordem' }) %></label>
                        <input type="number" class="form-control" id="cfgOptionSortOrder" value="0" />
                      </div>
                      <button type="button" class="btn btn-primary btn-sm" id="btnCfgAddOption"><i class="fa fa-plus"></i> <%= t('page.settings.options.addOption', { defaultValue: 'Adicionar opcao' }) %></button>
                    </div>

                    <table class="table table-striped table-bordered" id="cfgOptionTable">
                      <thead>
                        <tr>
                          <th><%= t('page.settings.options.value', { defaultValue: 'Value' }) %></th>
                          <th><%= t('page.settings.options.label', { defaultValue: 'Label' }) %></th>
                          <th><%= t('page.settings.options.color', { defaultValue: 'Cor' }) %></th>
                          <th><%= t('page.settings.options.sortOrder', { defaultValue: 'Ordem' }) %></th>
                          <th><%= t('page.settings.options.active', { defaultValue: 'Ativo' }) %></th>
                          <th><%= t('page.settings.options.actions', { defaultValue: 'Acoes' }) %></th>
                        </tr>
                      </thead>
                      <tbody></tbody>
                    </table>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="tab-pane" id="cfg-tab-email">
            <div class="cfg-toolbar">
              <button type="button" class="btn btn-primary btn-sm" id="btnCfgNewEmailIntegration"><i class="fa fa-plus"></i> <%= t('page.settings.email.new', { defaultValue: 'Nova integracao' }) %></button>
              <button type="button" class="btn btn-white btn-sm" id="btnCfgReloadEmailIntegration"><i class="fa fa-refresh"></i> <%= t('page.settings.common.reload', { defaultValue: 'Recarregar' }) %></button>
            </div>

            <table class="table table-striped table-bordered" id="cfgEmailTable">
              <thead>
                <tr>
                  <th><%= t('page.settings.email.provider', { defaultValue: 'Provider' }) %></th>
                  <th><%= t('page.settings.email.displayName', { defaultValue: 'Nome' }) %></th>
                  <th><%= t('page.settings.email.senderEmail', { defaultValue: 'Email remetente' }) %></th>
                  <th><%= t('page.settings.email.smtp', { defaultValue: 'SMTP' }) %></th>
                  <th><%= t('page.settings.email.active', { defaultValue: 'Ativo' }) %></th>
                  <th><%= t('page.settings.options.actions', { defaultValue: 'Acoes' }) %></th>
                </tr>
              </thead>
              <tbody></tbody>
            </table>
          </div>

          <div class="tab-pane" id="cfg-tab-landing">
            <div class="cfg-card">
              <div class="cfg-card-head"><%= t('page.settings.landing.title', { defaultValue: 'Configuração da Landing Page' }) %></div>
              <div class="cfg-card-body">
                <div class="row">
                  <div class="col-md-8 form-group">
                    <label for="cfgLandingPageUrl"><%= t('page.settings.landing.url', { defaultValue: 'Landing Page URL' }) %></label>
                    <input type="text" class="form-control" id="cfgLandingPageUrl" placeholder="https://..." />
                  </div>
                  <div class="col-md-4 form-group" style="padding-top:24px;">
                    <button type="button" class="btn btn-primary btn-sm" id="btnCfgLandingSaveUrl"><i class="fa fa-save"></i> <%= t('page.settings.common.save', { defaultValue: 'Salvar' }) %></button>
                  </div>
                </div>
                <div class="cfg-toolbar">
                  <button type="button" class="btn btn-success" id="btnCfgLandingOpenEditor"><i class="fa fa-pencil"></i> <%= t('page.settings.landing.editButton', { defaultValue: 'Editar minha landing page' }) %></button>
                  <div class="cfg-landing-meta">
                    <span class="cfg-badge"><strong><%= t('page.settings.landing.lastUpdate', { defaultValue: 'Última atualização' }) %>:</strong> <span id="cfgLandingUpdatedAt">-</span></span>
                    <span class="cfg-badge"><strong><%= t('page.settings.landing.lastPublish', { defaultValue: 'Última publicação' }) %>:</strong> <span id="cfgLandingPublishedAt">-</span></span>
                  </div>
                </div>
                <hr />
                <div class="form-group">
                  <label for="cfgLandingAiPrompt"><%= t('page.settings.landing.aiPrompt', { defaultValue: 'Prompt para IA gerar a landing page' }) %></label>
                  <textarea id="cfgLandingAiPrompt" class="form-control" rows="4" placeholder="<%= t('page.settings.landing.aiPromptPlaceholder', { defaultValue: 'Ex.: Crie uma landing page moderna para uma empresa de comércio exterior, com seção de benefícios, depoimentos e CTA para falar no WhatsApp.' }) %>"></textarea>
                </div>
                <div class="cfg-toolbar">
                  <div style="display:flex; gap:8px; flex-wrap:wrap;">
                    <button type="button" class="btn btn-warning" id="btnCfgLandingAiGenerate"><i class="fa fa-magic"></i> <%= t('page.settings.landing.aiGenerate', { defaultValue: 'Gerar landing com IA' }) %></button>
                    <button type="button" class="btn btn-info" id="btnCfgLandingAiPreview" disabled><i class="fa fa-eye"></i> <%= t('page.settings.landing.aiPreview', { defaultValue: 'Preview da landing IA' }) %></button>
                    <button type="button" class="btn btn-primary" id="btnCfgLandingAiUseInEditor" disabled><i class="fa fa-arrow-right"></i> <%= t('page.settings.landing.aiUseInEditor', { defaultValue: 'Usar no editor' }) %></button>
                  </div>
                  <div class="cfg-landing-meta">
                    <span class="cfg-badge"><strong><%= t('page.settings.landing.aiGeneratedAt', { defaultValue: 'Gerada em' }) %>:</strong> <span id="cfgLandingAiGeneratedAt">-</span></span>
                  </div>
                </div>
                <div id="cfgLandingAiVersions" class="cfg-landing-ai-versions cfg-muted"><%= t('page.settings.landing.aiVersionsHint', { defaultValue: 'Gere com IA para receber 3 versões de layout.' }) %></div>
              </div>
            </div>
          </div>

          <div class="tab-pane" id="cfg-tab-access">
            <div class="cfg-toolbar">
              <div>
                <button type="button" class="btn btn-primary btn-sm" id="btnCfgAccessReload"><i class="fa fa-refresh"></i> <%= t('page.settings.common.reload', { defaultValue: 'Recarregar' }) %></button>
                <button type="button" class="btn btn-success btn-sm" id="btnCfgAccessNewRole"><i class="fa fa-plus"></i> <%= t('page.settings.access.newRole', { defaultValue: 'Nova role' }) %></button>
                <button type="button" class="btn btn-danger btn-sm" id="btnCfgAccessDeleteRole"><i class="fa fa-trash"></i> <%= t('page.settings.access.deleteRole', { defaultValue: 'Excluir role' }) %></button>
              </div>
              <div>
                <button type="button" class="btn btn-primary btn-sm" id="btnCfgAccessSaveRolePerms"><i class="fa fa-save"></i> <%= t('page.settings.access.savePermissions', { defaultValue: 'Salvar permissões da role' }) %></button>
              </div>
            </div>

            <div class="cfg-access-layout">
              <div class="cfg-card">
                <div class="cfg-card-head"><%= t('page.settings.access.roles', { defaultValue: 'Roles do Tenant' }) %></div>
                <div class="cfg-card-body cfg-access-roles">
                  <ul class="cfg-area-list" id="cfgAccessRoleList"></ul>
                </div>
              </div>

              <div class="cfg-card">
                <div class="cfg-card-head"><%= t('page.settings.access.permissionsByTable', { defaultValue: 'Permissões por Tabela' }) %></div>
                <div class="cfg-card-body">
                  <div class="row">
                    <div class="col-md-4 form-group">
                      <label><%= t('page.settings.access.roleName', { defaultValue: 'Nome da role' }) %></label>
                      <input type="text" class="form-control" id="cfgAccessRoleName" />
                    </div>
                    <div class="col-md-3 form-group">
                      <label><%= t('page.settings.access.roleCode', { defaultValue: 'Código' }) %></label>
                      <input type="text" class="form-control" id="cfgAccessRoleCode" />
                    </div>
                    <div class="col-md-3 form-group">
                      <label><%= t('page.settings.access.roleStatus', { defaultValue: 'Status' }) %></label>
                      <select class="form-control" id="cfgAccessRoleActive">
                        <option value="1"><%= t('page.settings.access.active', { defaultValue: 'Ativa' }) %></option>
                        <option value="0"><%= t('page.settings.access.inactive', { defaultValue: 'Inativa' }) %></option>
                      </select>
                    </div>
                    <div class="col-md-2 form-group" style="padding-top:24px;">
                      <button type="button" class="btn btn-primary btn-sm" id="btnCfgAccessSaveRoleMeta"><i class="fa fa-save"></i> <%= t('page.settings.common.save', { defaultValue: 'Salvar' }) %></button>
                    </div>
                  </div>

                  <div class="form-group">
                    <label><%= t('page.settings.access.description', { defaultValue: 'Descrição' }) %></label>
                    <textarea class="form-control" rows="2" id="cfgAccessRoleDescription"></textarea>
                  </div>

                  <div class="form-group">
                    <label for="cfgAccessPermSearch"><%= t('page.settings.common.search', { defaultValue: 'Buscar' }) %></label>
                    <input type="text" class="form-control" id="cfgAccessPermSearch" placeholder="<%= t('page.settings.access.searchTables', { defaultValue: 'Buscar tabela por nome' }) %>" />
                  </div>

                  <table class="table table-striped table-bordered cfg-access-perm-table" id="cfgAccessPermTable">
                    <thead>
                      <tr>
                        <th><%= t('page.settings.access.table', { defaultValue: 'Tabela' }) %></th>
                        <th style="width:90px;">READ</th>
                        <th style="width:90px;">CREATE</th>
                        <th style="width:90px;">UPDATE</th>
                        <th style="width:90px;">DELETE</th>
                      </tr>
                    </thead>
                    <tbody></tbody>
                  </table>
                </div>
              </div>
            </div>

            <div class="cfg-card" style="margin-top:14px;">
              <div class="cfg-card-head"><%= t('page.settings.access.userAssignment', { defaultValue: 'Atribuição de Roles por Usuário' }) %></div>
              <div class="cfg-card-body">
                <div class="cfg-toolbar">
                  <div style="display:flex; gap:8px; align-items:center; flex-wrap:wrap;">
                    <input type="text" class="form-control input-sm" style="min-width:260px;" id="cfgAccessUserSearch" placeholder="<%= t('page.settings.access.searchUsers', { defaultValue: 'Buscar usuário por nome/email' }) %>" />
                    <button type="button" class="btn btn-white btn-sm" id="btnCfgAccessSearchUsers"><i class="fa fa-search"></i> <%= t('page.settings.common.search', { defaultValue: 'Buscar' }) %></button>
                  </div>
                  <button type="button" class="btn btn-primary btn-sm" id="btnCfgAccessSaveUserRoles"><i class="fa fa-save"></i> <%= t('page.settings.access.saveUserRoles', { defaultValue: 'Salvar roles do usuário' }) %></button>
                </div>

                <div class="row">
                  <div class="col-md-6">
                    <div class="cfg-access-users">
                      <table class="table table-striped table-bordered cfg-table-pointer" id="cfgAccessUsersTable">
                        <thead>
                          <tr>
                            <th><%= t('page.settings.access.user', { defaultValue: 'Usuário' }) %></th>
                            <th><%= t('page.settings.access.legacyRole', { defaultValue: 'Role Legada' }) %></th>
                          </tr>
                        </thead>
                        <tbody></tbody>
                      </table>
                    </div>
                  </div>
