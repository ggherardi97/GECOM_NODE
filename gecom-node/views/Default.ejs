        var deptLabels = Object.keys(deptCounts).sort(function (a, b) { return deptCounts[b] - deptCounts[a]; }).slice(0, 8);
        var deptValues = deptLabels.map(function (k) { return deptCounts[k]; });

        hrDepartmentChart = buildOrUpdateChart(hrDepartmentChart, "hrDepartmentChart", {
