    async function loadMyProcessesDashboard() {
      $("#companyNameText").text(pickCompanyName());

      var companyId = pickCompanyId();
      if (!companyId) {
        $("#timelineEmpty").text("Não foi possível identificar a empresa logada (company_id).");
        $("#top2ProcessesTbody").html("<tr><td colspan='3'>Empresa não identificada.</td></tr>");
        return;
      }

      try {
        window.GECOM?.spinner?.show("Carregando dashboard...");

        var procRes = await fetchJson("/api/processes?company_id=" + encodeURIComponent(String(companyId)));

        try {
          var notifRows = [];
          if (window.GECOM_NOTIFICATIONS?.fetchTopByCompany) {
            notifRows = await window.GECOM_NOTIFICATIONS.fetchTopByCompany();
          }
          renderDashboardNotifications(notifRows);
        } catch (notifErr) {
          console.error("Notifications dashboard error:", notifErr);
          renderDashboardNotifications([]);
        }

        var processes = normalizeArrayResponse(procRes);

        $("#kpiProcessCount").text(String(processes.length));
        $("#kpiClosedCount").text(String(processes.filter(function (p) { return Number(p?.status) === 4; }).length));

        var year = new Date().getFullYear();
        var totalYear = 0;
        var currencyCode = "BRL";

        processes.forEach(function (p) {
          var dt = pickProcessDateForYearFilter(p);
          if (!dt) return;
          var d = new Date(dt || 0);
          if (Number.isNaN(d.getTime())) return;
          if (d.getFullYear() !== year) return;

          totalYear += toNumber(pickProcessTotalValue(p));
        });

        $("#kpiTotalYear").text(moneyPtBr(totalYear, currencyCode));
        $("#lineTotalYear").text(moneyPtBr(totalYear, currencyCode));
        $("#lastUpdateAtCompany").text(formatDateTimePtBr(new Date().toISOString()));

        var labels = ["Jan", "Fev", "Mar", "Abr", "Mai", "Jun", "Jul", "Ago", "Set", "Out", "Nov", "Dez"];
        var monthly = new Array(12).fill(0);

        processes.forEach(function (p) {
          var dt = pickProcessDateForYearFilter(p);
          if (!dt) return;
          var d = new Date(dt || 0);
          if (Number.isNaN(d.getTime())) return;
          if (d.getFullYear() !== year) return;

          monthly[d.getMonth()] += toNumber(pickProcessTotalValue(p));
        });

        buildLineChartCompany(labels, monthly, currencyCode);

        // Top 2
        var top2 = processes.slice().sort(function (a, b) {
          return new Date(pickProcessCreatedAt(b) ?? 0) - new Date(pickProcessCreatedAt(a) ?? 0);
        }).slice(0, 2);

        if (!top2.length) {
          $("#top2ProcessesTbody").html("<tr><td colspan='3'>Nenhum processo encontrado.</td></tr>");
        } else {
          $("#top2ProcessesTbody").html(top2.map(function (p) {
            var num = escapeHtml(pickProcessNumber(p));
            var stLabel = escapeHtml(getProcessStatusLabel(p));
            var stClass = escapeHtml(getProcessStatusCssFull(p));
            var created = escapeHtml(formatDateTimePtBr(pickProcessCreatedAt(p)));
            return `
              <tr style="cursor:pointer;" onclick="window.location='ProcessDetail?id=${encodeURIComponent(String(p?.id || ''))}'">
                <td><strong>${num}</strong></td>
                <td><span class="${stClass}">${stLabel}</span></td>
                <td>${created}</td>
              </tr>
            `;
          }).join(""));
        }

        // Timeline: prioriza processos em andamento (1) e próximo do prazo (2), mais recente.
        var active = processes
          .filter(function (p) {
            var st = Number(p?.status);
            return st === 1 || st === 2;
          })
          .sort(function (a, b) { return new Date(pickProcessCreatedAt(b) ?? 0) - new Date(pickProcessCreatedAt(a) ?? 0); })[0];

        if (!active?.id) {
          $("#timelineEmpty").text("Nenhum processo em andamento ou próximo do prazo foi encontrado.");
          $("#timelineBadge").text("Sem processo para timeline");
          return;
        }

        $("#timelineBadge").text("Processo recente: " + (active?.process_number || active?.id));

        var detail = await fetchJson("/api/processes/" + encodeURIComponent(String(active.id)));
        var events = detail?.events || detail?.Events || detail?.eventos || [];
        renderTimeline(events);

      } catch (e) {
        console.error("DashboardCompany error:", e);
        $("#top2ProcessesTbody").html("<tr><td colspan='3'>Erro ao carregar.</td></tr>");
        $("#timelineEmpty").text(e?.message || "Erro ao carregar a timeline.");
      } finally {
        window.GECOM?.spinner?.hide();
      }
    }

    var financeCashChart = null;
    var hrDepartmentChart = null;
    var servicesStatusChart = null;
    var poStatusChart = null;
    var hrVacationCalendarReady = false;

    function destroyChart(chart) {
      if (!chart) return null;
      try { chart.destroy(); } catch (e) { }
      return null;
    }

    function buildOrUpdateChart(current, canvasId, config) {
      var el = document.getElementById(canvasId);
      if (!el) return current;
      current = destroyChart(current);
      var ctx = el.getContext("2d");
      return new Chart(ctx, config);
    }

    function normalizeFoldedText(value) {
      var raw = String(value || "");
      try {
        raw = raw.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
      } catch (e) { }
      return raw.trim().toUpperCase();
    }

    function isVacationLeaveRequest(row) {
      var status = toStatusText(row);
      if (status.includes("CANCEL") || status.includes("REJECT")) return false;

      var leaveType = row?.leave_type || row?.leaveType || {};
      var code = normalizeFoldedText(leaveType?.code || row?.leave_type_code || row?.leaveTypeCode);
      var name = normalizeFoldedText(leaveType?.name || row?.leave_type_name || row?.leaveTypeName);
      return code.includes("FERI") || code.includes("VACAT") || name.includes("FERI") || name.includes("VACAT");
    }

    function toIsoDate(value) {
      var d = parseDateSafe(value);
      if (!d) return null;
      return d.toISOString().slice(0, 10);
    }

    function toLeaveDateRange(row) {
      var startRaw = row?.start_datetime || row?.start_date || row?.startDate || row?.startDateTime || null;
      var endRaw = row?.end_datetime || row?.end_date || row?.endDate || row?.endDateTime || startRaw;
      var start = parseDateSafe(startRaw);
      var end = parseDateSafe(endRaw || startRaw);
      if (!start) return null;
      if (!end) end = start;

      var startIso = toIsoDate(start);
      var endExclusive = new Date(end.getFullYear(), end.getMonth(), end.getDate() + 1);
      var endIso = toIsoDate(endExclusive);
      if (!startIso || !endIso) return null;
      return { startIso: startIso, endIso: endIso };
    }

    function buildHrVacationEvents(leaves) {
      return (Array.isArray(leaves) ? leaves : [])
        .filter(isVacationLeaveRequest)
        .map(function (row) {
          var range = toLeaveDateRange(row);
          if (!range) return null;
          var employee = row?.employee?.full_name || row?.employee_name || "Colaborador";
          var leaveType = row?.leave_type || row?.leaveType || {};
          var leaveTypeName = leaveType?.name || row?.leave_type_name || "Férias";
          var color = leaveType?.color || "#23c6c8";
          return {
            title: String(employee) + " - " + String(leaveTypeName),
            start: range.startIso,
            end: range.endIso,
            allDay: true,
            color: color,
          };
        })
        .filter(function (item) { return !!item; });
    }

    function renderHrVacationCalendar(leaves) {
      var $calendar = $("#hrVacationCalendar");
      if (!$calendar.length) return;
      if (typeof $calendar.fullCalendar !== "function") return;

      var events = buildHrVacationEvents(leaves);
      if (!hrVacationCalendarReady) {
        $calendar.fullCalendar({
          defaultView: "month",
          header: {
            left: "prev,next today",
            center: "title",
            right: "month",
          },
          buttonText: {
            today: "Hoje",
            month: "Mês",
          },
          editable: false,
          eventLimit: true,
          events: events,
        });
        hrVacationCalendarReady = true;
        return;
      }

      $calendar.fullCalendar("removeEvents");
      $calendar.fullCalendar("addEventSource", events);
      $calendar.fullCalendar("rerenderEvents");
    }

    function isFinancialOpen(row) {
      var st = toStatusText(row);
      if (st === "CANCELED" || st === "CANCELLED") return false;
      if (st === "PAID" || st === "PAGO") return false;
      return pickMoney(row) > 0;
    }

    async function loadFinanceDashboard() {
      var year = new Date().getFullYear();
      var nowDate = new Date();
      try {
        var responses = await Promise.all([
          fetchJsonOrEmpty("/api/finance/receivables"),
          fetchJsonOrEmpty("/api/finance/payables"),
        ]);

        var receivables = normalizeArrayResponse(responses[0]);
        var payables = normalizeArrayResponse(responses[1]);

        var recOpen = receivables.filter(isFinancialOpen);
        var payOpen = payables.filter(isFinancialOpen);

        var recOpenSum = sumBy(recOpen, pickMoney);
        var payOpenSum = sumBy(payOpen, pickMoney);
        var overdueCount = recOpen.concat(payOpen).filter(function (row) {
          var due = parseDateSafe(pickAnyDate(row));
          return due && due < nowDate;
        }).length;

        $("#kpiFinanceReceivablesOpen").text(moneyCurrencyPtBr(recOpenSum, "BRL"));
        $("#kpiFinancePayablesOpen").text(moneyCurrencyPtBr(payOpenSum, "BRL"));
        $("#kpiFinanceNet").text(moneyCurrencyPtBr(recOpenSum - payOpenSum, "BRL"));
        $("#kpiFinanceOverdueCount").text(String(overdueCount));

        var inByMonth = new Array(12).fill(0);
        var outByMonth = new Array(12).fill(0);
        recOpen.forEach(function (row) {
          var d = parseDateSafe(pickAnyDate(row));
          if (!d || d.getFullYear() !== year) return;
          inByMonth[d.getMonth()] += pickMoney(row);
        });
        payOpen.forEach(function (row) {
          var d = parseDateSafe(pickAnyDate(row));
          if (!d || d.getFullYear() !== year) return;
          outByMonth[d.getMonth()] += pickMoney(row);
        });

        financeCashChart = buildOrUpdateChart(financeCashChart, "financeCashChart", {
          type: "line",
          data: {
            labels: monthsPt,
            datasets: [
              { label: "Entradas", borderColor: "rgba(26,179,148,1)", backgroundColor: "rgba(26,179,148,.12)", data: inByMonth },
              { label: "Saídas", borderColor: "rgba(220,53,69,1)", backgroundColor: "rgba(220,53,69,.10)", data: outByMonth },
            ],
          },
          options: { responsive: true, maintainAspectRatio: false },
        });

        var upcoming = recOpen.map(function (row) {
          return { kind: "Receber", title: pickAnyTitle(row), due: parseDateSafe(pickAnyDate(row)), amount: pickMoney(row) };
        }).concat(payOpen.map(function (row) {
          return { kind: "Pagar", title: pickAnyTitle(row), due: parseDateSafe(pickAnyDate(row)), amount: pickMoney(row) };
        }));

        upcoming = upcoming
          .filter(function (row) { return !!row.due; })
          .sort(function (a, b) { return a.due - b.due; })
          .slice(0, 8);

        var rows = upcoming.map(function (row) {
          var kindClass = row.kind === "Receber" ? "label label-info" : "label label-danger";
          return `<tr>
            <td><span class="${kindClass}">${escapeHtml(row.kind)}</span></td>
            <td>${escapeHtml(row.title)}</td>
            <td>${escapeHtml(formatDatePtBr(row.due))}</td>
            <td>${escapeHtml(moneyCurrencyPtBr(row.amount, "BRL"))}</td>
          </tr>`;
        }).join("");

        renderTableRows($("#financeUpcomingTbody"), rows, 4, "Sem títulos próximos.");
      } catch (e) {
        console.error("Finance dashboard error:", e);
        renderTableRows($("#financeUpcomingTbody"), "", 4, "Erro ao carregar dados financeiros.");
      }
    }

    async function loadHrDashboard() {
      try {
        var responses = await Promise.all([
          fetchJsonOrEmpty("/api/hr/employees"),
          fetchJsonOrEmpty("/api/hr/leave-requests"),
          fetchJsonOrEmpty("/api/hr/department-assignments"),
