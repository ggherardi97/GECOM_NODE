        });

        var leaveRows = pendingLeaves
          .slice()
          .sort(function (a, b) { return new Date(pickAnyDate(b) || 0) - new Date(pickAnyDate(a) || 0); })
          .slice(0, 7)
          .map(function (row) {
            var employee = row?.employee?.full_name || row?.employee_name || "-";
            var start = formatDatePtBr(row?.start_datetime || row?.start_date || row?.startDate);
            var end = formatDatePtBr(row?.end_datetime || row?.end_date || row?.endDate);
            var status = toStatusText(row) || "-";
            return `<tr>
              <td>${escapeHtml(employee)}</td>
              <td>${escapeHtml(start)} - ${escapeHtml(end)}</td>
              <td><span class="dash-pill">${escapeHtml(status)}</span></td>
            </tr>`;
          })
          .join("");

        renderTableRows($("#hrLeavePendingTbody"), leaveRows, 3, "Sem solicitações pendentes.");
        renderHrVacationCalendar(leaves);
      } catch (e) {
        console.error("HR dashboard error:", e);
        renderTableRows($("#hrLeavePendingTbody"), "", 3, "Erro ao carregar dados de RH.");
        renderHrVacationCalendar([]);
      }
    }

    async function loadServicesDashboard() {
      var nowDate = new Date();
      try {
        var responses = await Promise.all([
          fetchJsonOrEmpty("/api/service/incidents"),
          fetchJsonOrEmpty("/api/service/tasks"),
          fetchJsonOrEmpty("/api/service/sla/instance-kpis"),
          fetchJsonOrEmpty("/api/service/queues"),
        ]);
        var incidents = normalizeArrayResponse(responses[0]);
        var tasks = normalizeArrayResponse(responses[1]);
        var slaKpis = normalizeArrayResponse(responses[2]);
        var queues = normalizeArrayResponse(responses[3]);

        var openIncidents = incidents.filter(function (row) { return isOpenLikeStatus(toStatusText(row)); });
        var overdueIncidents = openIncidents.filter(function (row) {
          var due = parseDateSafe(row?.due_at || row?.dueAt || row?.target_at || row?.targetAt);
          return due && due < nowDate;
        });
        var openTasks = tasks.filter(function (row) { return isOpenLikeStatus(toStatusText(row)); });
        var breachedSla = slaKpis.filter(function (row) {
          var st = toStatusText(row);
          return st.includes("BREACH") || st.includes("FAILED");
        });

        $("#kpiSvcOpenIncidents").text(String(openIncidents.length));
        $("#kpiSvcOverdueIncidents").text(String(overdueIncidents.length));
        $("#kpiSvcOpenTasks").text(String(openTasks.length));
        $("#kpiSvcBreachedSla").text(String(breachedSla.length));

        var statusCounts = {};
        incidents.forEach(function (row) {
          var st = toStatusText(row) || "SEM STATUS";
          statusCounts[st] = (statusCounts[st] || 0) + 1;
        });
        var statusLabels = Object.keys(statusCounts);
        var statusValues = statusLabels.map(function (k) { return statusCounts[k]; });

        servicesStatusChart = buildOrUpdateChart(servicesStatusChart, "servicesStatusChart", {
          type: "doughnut",
          data: {
            labels: statusLabels,
            datasets: [{ data: statusValues, backgroundColor: ["#1ab394", "#1c84c6", "#f8ac59", "#ed5565", "#23c6c8", "#999"] }],
          },
          options: { responsive: true, maintainAspectRatio: false, legend: { position: "bottom" } },
        });

        var queueNameById = {};
        queues.forEach(function (q) {
          queueNameById[String(q?.id || "")] = q?.name || q?.code || "Fila";
        });
        var queueCounts = {};
        openIncidents.forEach(function (row) {
          var queueId = String(row?.queue_id || row?.queue?.id || "");
          var name = queueNameById[queueId] || row?.queue?.name || "Sem fila";
          queueCounts[name] = (queueCounts[name] || 0) + 1;
        });
        var queueRows = Object.keys(queueCounts)
          .sort(function (a, b) { return queueCounts[b] - queueCounts[a]; })
          .slice(0, 8)
          .map(function (name) { return `<tr><td>${escapeHtml(name)}</td><td>${queueCounts[name]}</td></tr>`; })
          .join("");

        renderTableRows($("#servicesQueueLoadTbody"), queueRows, 2, "Sem filas com incidentes abertos.");
      } catch (e) {
        console.error("Services dashboard error:", e);
        renderTableRows($("#servicesQueueLoadTbody"), "", 2, "Erro ao carregar dados de Services.");
      }
    }

    async function loadProjectOperationsDashboard() {
      var nowDate = new Date();
      var dueSoonLimit = new Date(nowDate.getTime() + (15 * 24 * 60 * 60 * 1000));
      try {
        var responses = await Promise.all([
          fetchJsonOrEmpty("/api/project-operations/projects"),
          fetchJsonOrEmpty("/api/project-operations/work-orders"),
          fetchJsonOrEmpty("/api/project-operations/deliverables"),
          fetchJsonOrEmpty("/api/project-operations/milestones"),
        ]);
        var projects = normalizeArrayResponse(responses[0]);
        var workOrders = normalizeArrayResponse(responses[1]);
        var deliverables = normalizeArrayResponse(responses[2]);
        var milestones = normalizeArrayResponse(responses[3]);

        var activeProjects = projects.filter(function (row) { return isOpenLikeStatus(toStatusText(row)); });
        var openWorkOrders = workOrders.filter(function (row) { return isOpenLikeStatus(toStatusText(row)); });

        var dueSoonDeliverables = deliverables.filter(function (row) {
          var due = parseDateSafe(row?.due_date || row?.dueDate || row?.target_end_date || row?.targetEndDate);
          if (!due) return false;
          if (!isOpenLikeStatus(toStatusText(row))) return false;
          return due >= nowDate && due <= dueSoonLimit;
        });

        var overdueMilestones = milestones.filter(function (row) {
          var due = parseDateSafe(row?.due_date || row?.dueDate || row?.target_end_date || row?.targetEndDate);
          if (!due) return false;
          return due < nowDate && isOpenLikeStatus(toStatusText(row));
        });

        $("#kpiPoActiveProjects").text(String(activeProjects.length));
        $("#kpiPoOpenWorkOrders").text(String(openWorkOrders.length));
        $("#kpiPoDueSoonDeliverables").text(String(dueSoonDeliverables.length));
        $("#kpiPoOverdueMilestones").text(String(overdueMilestones.length));

        var woStatusCounts = {};
        workOrders.forEach(function (row) {
          var st = toStatusText(row) || "SEM STATUS";
          woStatusCounts[st] = (woStatusCounts[st] || 0) + 1;
        });
        var woLabels = Object.keys(woStatusCounts);
        var woValues = woLabels.map(function (k) { return woStatusCounts[k]; });

        poStatusChart = buildOrUpdateChart(poStatusChart, "poWorkOrdersStatusChart", {
          type: "bar",
          data: {
            labels: woLabels,
            datasets: [{ label: "Work Orders", backgroundColor: "rgba(102,16,242,0.65)", borderColor: "rgba(102,16,242,1)", data: woValues }],
          },
          options: { responsive: true, maintainAspectRatio: false, legend: { display: false } },
        });

        var deliverableRows = dueSoonDeliverables
          .slice()
          .sort(function (a, b) {
            return new Date(a?.due_date || a?.dueDate || 0) - new Date(b?.due_date || b?.dueDate || 0);
          })
          .slice(0, 8)
          .map(function (row) {
            var title = row?.name || row?.title || row?.code || "-";
            var due = formatDatePtBr(row?.due_date || row?.dueDate || row?.target_end_date || row?.targetEndDate);
            var status = toStatusText(row) || "-";
            return `<tr>
              <td>${escapeHtml(title)}</td>
              <td>${escapeHtml(due)}</td>
              <td><span class="dash-pill">${escapeHtml(status)}</span></td>
            </tr>`;
          })
          .join("");

        renderTableRows($("#poUpcomingDeliverablesTbody"), deliverableRows, 3, "Sem entregas próximas.");
      } catch (e) {
        console.error("Project & Operations dashboard error:", e);
        renderTableRows($("#poUpcomingDeliverablesTbody"), "", 3, "Erro ao carregar dados de Project & Operations.");
      }
    }

    // -------------------- Init --------------------
    buildDashPicker();
    setSortIndicator();
    loadDashboard();
  });
</script>




